# BLW Studio — local environment template.
#
# Copy this file to `.env.local` (gitignored) and fill in the values from the
# Vercel project (Settings -> Environment Variables). NEVER commit real keys.
#
# ─── Client-exposed (VITE_ prefix = bundled into the browser build) ──────────
# The anon key is the PUBLISHABLE key, safe to ship to the browser. It is NOT
# the service-role key.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ─── Server-only secret (used by the /api serverless functions) ──────────────
# Required only when running the API locally with `vercel dev`. NEVER prefix
# with VITE_ and NEVER expose it to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# ─── Optional (match production if you need these locally) ───────────────────
# RESEND_API_KEY=         # signup / claim notification emails
# NOTIFY_EMAIL=           # where signup notifications are sent

# ─── Running locally ─────────────────────────────────────────────────────────
#   npm run dev    -> Vite only. Public surfaces + client Supabase work; the
#                     /api routes do NOT run, so service-role features are dark.
#   vercel dev     -> Vite + /api functions. Full fidelity; needs all three
#                     vars above. Log in with your real master account to verify
#                     master-gated surfaces locally.
